# Copy this file to .env.local and fill in the values from Supabase
# Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Used to build the magic-link redirect URL.
# In production this should be https://soyreinaldo.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (test mode while developing — switch to LIVE keys in production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
